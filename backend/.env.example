# Backend Configuration

# Server
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# Logging
LOG_LEVEL=info

# CrUX API Configuration
# Get your API key from: https://developers.google.com/chrome-ux-report/api/getting-started
CRUX_API_KEY=your_crux_api_key_here

# Google Cloud Configuration
# For BigQuery access: https://developer.chrome.com/docs/crux/bigquery
GOOGLE_PROJECT_ID=your_google_project_id_here
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/credentials.json

# Cache Configuration
CACHE_TTL=300
USE_DUMMY_DATA=true
